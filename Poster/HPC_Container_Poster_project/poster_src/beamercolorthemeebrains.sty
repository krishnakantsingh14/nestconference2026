% EBRAINS color theme (teal-green primary + magenta accent)
\definecolor{ebrteal}{HTML}{0E8C6E}   % primary (logo green/teal)
\definecolor{ebrgreen}{HTML}{00B26C}
\definecolor{ebrmag}{HTML}{DE0054}    % accent
\definecolor{ebrblue}{HTML}{1374C3}
\definecolor{ebrviolet}{HTML}{836C91}
\definecolor{lightgreen}{HTML}{E8F6F0}
\definecolor{lightgray}{HTML}{EAF1FA}
\definecolor{verylightgray}{HTML}{F4F8F6}

\setbeamercolor{background canvas}{bg=verylightgray}
\setbeamercolor{qr}{bg=verylightgray}
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
